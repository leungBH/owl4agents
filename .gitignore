# Local AI/IDE tool state
.claude/
.codex/
.trae/
openspec/
doc/
backup/
version.md

# Local-only evidence and scratch space
reports/
temp/
local/

# Generated example outputs (runtime logs, transcripts, screenshots)
temp/examples/

# Generated workflow reports and local agent traces
reports/workflow/
reports/acceptance/
local-traces/

# Private or sensitive ontology inputs
test/owl_files/
test/corpus/realworld-local/
test/corpus/downloads/
test/corpus/large/
test/corpus/benchmarks/ore/

# Gradle
.gradle/
.gradle-local/
build/
modules/**/build/
modules/**/bin/
**/build/test-results/
**/build/reports/tests/
*.zip
# Do NOT ignore gradlew / gradlew.bat — they are required for reproducible builds
# Do NOT ignore gradle-wrapper.jar — it must be committed for wrapper to work

# IDE
.idea/
*.iml
.vscode/settings.json

# Java
*.class
# Ignore built jars but NOT the Gradle wrapper jar
modules/**/build/libs/*.jar
modules/**/build/libs/*.sha256
*.war
# Maven metadata extracted by OWL API / Jena dependency resolution
META-INF/
/org/

# OS
.DS_Store
Thumbs.db

# owl4agents local workspace (created at runtime)
.owl4agents/

# Root-level Node.js tooling (docx/pptx generation, not part of v0.5)
/node_modules/
/package.json
/package-lock.json
/gen_docx.js
# Smoke test temporary workspaces
*-smoke/
v*-smoke-*/

# Timestamped final workspace directories
v*-final-*/

# Numeric scratch files at root
/[0-9]*/

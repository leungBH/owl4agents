@prefix : <http://example.org/minimal#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/minimal> a owl:Ontology ;
  rdfs:label "Minimal Ontology" ;
  rdfs:comment "A minimal OWL ontology for basic import and summary testing." .

:MinimalClass a owl:Class ;
  rdfs:label "Minimal Class" ;
  rdfs:comment "The only class in this minimal ontology." .
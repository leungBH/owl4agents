@prefix : <http://example.org/sparql-safety#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/sparql-safety> a owl:Ontology ;
  rdfs:label "SPARQL Safety Ontology" ;
  rdfs:comment "A small ontology for testing SPARQL SELECT, ASK, CONSTRUCT, DESCRIBE, and update rejection." .

:City a owl:Class ;
  rdfs:label "City" .

:Country a owl:Class ;
  rdfs:label "Country" .

:locatedIn a owl:ObjectProperty ;
  rdfs:label "located in" ;
  rdfs:domain :City ;
  rdfs:range :Country .

:hasPopulation a owl:DatatypeProperty ;
  rdfs:label "has population" ;
  rdfs:domain :City ;
  rdfs:range xsd:integer .

:paris a :City ;
  rdfs:label "Paris" ;
  :locatedIn :france ;
  :hasPopulation 2161000 .

:france a :Country ;
  rdfs:label "France" .

:berlin a :City ;
  rdfs:label "Berlin" ;
  :locatedIn :germany ;
  :hasPopulation 3645000 .

:germany a :Country ;
  rdfs:label "Germany" .
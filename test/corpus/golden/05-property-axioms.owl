@prefix : <http://example.org/property-axioms#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/property-axioms> a owl:Ontology ;
  rdfs:label "Property Axioms Ontology" ;
  rdfs:comment "Tests object property and data property axioms including domain, range, inverse, and hierarchy." .

:Person a owl:Class ;
  rdfs:label "Person" .

:Organization a owl:Class ;
  rdfs:label "Organization" .

:Document a owl:Class ;
  rdfs:label "Document" .

# Object properties with domain and range
:worksFor a owl:ObjectProperty ;
  rdfs:label "works for" ;
  rdfs:comment "Indicates that a person works for an organization." ;
  rdfs:domain :Person ;
  rdfs:range :Organization .

:employs a owl:ObjectProperty ;
  rdfs:label "employs" ;
  rdfs:comment "Indicates that an organization employs a person." ;
  rdfs:domain :Organization ;
  rdfs:range :Person ;
  owl:inverseOf :worksFor .

:hasParent a owl:ObjectProperty ;
  rdfs:label "has parent" ;
  rdfs:domain :Person ;
  rdfs:range :Person .

:hasChild a owl:ObjectProperty ;
  rdfs:label "has child" ;
  rdfs:domain :Person ;
  rdfs:range :Person ;
  owl:inverseOf :hasParent .

# Property hierarchy
:hasMother a owl:ObjectProperty ;
  rdfs:label "has mother" ;
  rdfs:subPropertyOf :hasParent ;
  rdfs:domain :Person ;
  rdfs:range :Person .

:hasFather a owl:ObjectProperty ;
  rdfs:label "has father" ;
  rdfs:subPropertyOf :hasParent ;
  rdfs:domain :Person ;
  rdfs:range :Person .

# Data properties with domain and range/datatype
:hasName a owl:DatatypeProperty ;
  rdfs:label "has name" ;
  rdfs:comment "The full name of a person." ;
  rdfs:domain :Person ;
  rdfs:range xsd:string .

:hasAge a owl:DatatypeProperty ;
  rdfs:label "has age" ;
  rdfs:comment "The age of a person in years." ;
  rdfs:domain :Person ;
  rdfs:range xsd:integer .

:hasSalary a owl:DatatypeProperty ;
  rdfs:label "has salary" ;
  rdfs:domain :Person ;
  rdfs:range xsd:decimal .

# Data property hierarchy
:hasFirstName a owl:DatatypeProperty ;
  rdfs:label "has first name" ;
  rdfs:subPropertyOf :hasName ;
  rdfs:domain :Person ;
  rdfs:range xsd:string .

:hasLastName a owl:DatatypeProperty ;
  rdfs:label "has last name" ;
  rdfs:subPropertyOf :hasName ;
  rdfs:domain :Person ;
  rdfs:range xsd:string .